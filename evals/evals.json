{
  "skill_name": "product-selector",
  "schema_version": 3,
  "live_fixture_policy": {
    "minimum_fixtures": 2,
    "required_endpoints": [
      "ProductRequest",
      "CategoryRequest"
    ],
    "capture_rule": "Capture with scripts/sorftime_call.py, redact credentials and personal data, then record endpoint, domain, captured_at and SHA-256."
  },
  "fixture_catalog": [
    {
      "path": "fixtures/category-request-payload.json",
      "provenance": "synthetic",
      "sha256": "2ada3c2d29cedd20d3c87ea5172f00072ec9b24aace122d71431594d7c3341d3",
      "purpose": "Budget and wrapper request fixture"
    },
    {
      "path": "fixtures/expected-report.md",
      "provenance": "synthetic",
      "sha256": "20678b1501fac0f9d992408768f1f7b9441049873f8609b2391108896e1a1ace",
      "purpose": "Report contract fixture"
    },
    {
      "path": "fixtures/sample-electronics-category.json",
      "provenance": "synthetic",
      "sha256": "b64bc625f81ee26121d020f89e60576c525411901348e63b9e54e697c21a00bb",
      "purpose": "Attribute and cross-analysis fixture"
    },
    {
      "path": "fixtures/sample-product-request.json",
      "provenance": "synthetic",
      "sha256": "6a1178bf6efbf21a82c0391d48d31e585d90f61a5d29c63f6c55d34c464c5fd8",
      "purpose": "Monitoring payload fixture"
    },
    {
      "path": "fixtures/sample-reviews.json",
      "provenance": "synthetic",
      "sha256": "0c216e24e3a00e84a7fb8341ed952abca22988af35da2b611f3aaba9038ae33e",
      "purpose": "VOC bundle fixture"
    }
  ],
  "evals": [
    {
      "id": "asin-full-dry-run",
      "prompt": "帮我分析 B0CVM8TXHP，先不要写飞书，给出市场和财务两层判断。",
      "mode": "full",
      "write_mode": "dry-run",
      "expected_checks": [
        "Market Decision and Financial Decision are separate",
        "missing cost triggers reverse finance instead of skipping finance",
        "no live Feishu mutation",
        "every numeric claim has a source or assumption label"
      ],
      "expected_api_budget_max": 60
    },
    {
      "id": "keyword-quick",
      "prompt": "nail drill 这个品类值得做吗？控制在 25 积分以内。",
      "mode": "quick",
      "write_mode": "dry-run",
      "expected_checks": [
        "three keyword dimensions or an explicit missing-data reason",
        "API plan does not exceed 25",
        "blank supply is not called blue ocean without demand evidence"
      ],
      "expected_api_budget_max": 25
    },
    {
      "id": "batch-plan-only",
      "prompt": "产品初选表里待分析的先给我批量计划，不要开始写。",
      "mode": "batch",
      "write_mode": "dry-run",
      "expected_checks": [
        "deduplicated analysis keys",
        "item count and estimated API cost",
        "parallelism no greater than configured maximum",
        "no live write"
      ]
    },
    {
      "id": "unknown-category-dimensions",
      "prompt": "用 fixture 分析这个未配置品类的属性结构。",
      "files": [
        "fixtures/sample-electronics-category.json"
      ],
      "expected_checks": [
        "dimension-draft.json is produced",
        "requires_dimension_confirmation is true",
        "draft dimensions are not used as final opportunity evidence"
      ]
    },
    {
      "id": "fixture-report-lint",
      "prompt": "校验 fixture 报告是否满足正式交付标准。",
      "files": [
        "fixtures/expected-report.md"
      ],
      "expected_checks": [
        "all required sections are present",
        "at least three Sorftime source types are cited",
        "market and finance decisions are separated",
        "no unresolved placeholder remains"
      ]
    }
  ]
}
